# Recensioni Google — copia questo file in ".env.local" e inserisci i tuoi valori.
# .env.local NON viene versionato (è in .gitignore).

# (OBBLIGATORIA) API key di Google Cloud con "Places API (New)" abilitata.
GOOGLE_PLACES_API_KEY=

# (Opzionale) Place ID dell'attività, formato "ChIJ...".
# Se lo lasci vuoto, lo script trova l'attività cercandola per nome (vedi sotto).
GOOGLE_PLACE_ID=

# (Opzionale) Testo di ricerca per individuare l'attività se manca il Place ID.
# Default già impostato nello script: "Acquadirete di Stefano Piconese, Via 1° Maggio 6, Montespertoli".
GOOGLE_PLACE_QUERY=
